# Copy to `.env` and adjust values as needed for your local setup.

# Used by the Next.js app (and by Prisma migrate/generate via prisma.config.ts).
# When running `npm run dev` locally, the DB host is `localhost`.
# In Docker Compose the `app` service overrides this to use `db` as the hostname.
DATABASE_URL="postgresql://nextrep:nextrep@localhost:5432/nextrep?schema=public"

# Postgres credentials used by the `db` service in docker-compose.yml.
POSTGRES_USER=nextrep
POSTGRES_PASSWORD=nextrep
POSTGRES_DB=nextrep
