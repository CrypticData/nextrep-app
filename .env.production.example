# Copy to `.env` on your deploy host and fill in real values.
# These are required by docker-compose.prod.yml.

# Postgres credentials. Use a strong, randomly generated password.
POSTGRES_USER=nextrep
POSTGRES_PASSWORD=
POSTGRES_DB=nextrep

# Image tag to deploy. Bump this and re-run `docker compose pull && docker compose up -d` to upgrade.
APP_VERSION=1.0.0

# Host port for the app. Override only if 3000 is already taken on this host.
# This is what you point your browser (or Tailscale) at. Postgres is not
# published to the host — the app reaches it over the compose network.
APP_HOST_PORT=3000
