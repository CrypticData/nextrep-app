# Copy to `.env` on your deploy host and fill in real values.
# These are required by docker-compose.prod.yml.

# Postgres credentials. Use a strong, randomly generated password.
POSTGRES_USER=nextrep
POSTGRES_PASSWORD=
POSTGRES_DB=nextrep

# Image tag to deploy. Bump this and re-run `docker compose pull && docker compose up -d` to upgrade.
APP_VERSION=1.0.0

# Host ports. Override these only if the defaults clash with another service
# already running on the host. `APP_HOST_PORT` is what you point your browser
# (or Tailscale) at. `POSTGRES_HOST_PORT` is bound to loopback only.
APP_HOST_PORT=3000
POSTGRES_HOST_PORT=5432
